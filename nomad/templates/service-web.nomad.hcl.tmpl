# Rendered by the deploy service on promotion. Never hand-edited:
# a config change is a new render + new allocation, not a patch in place.
#
# {{app_id}}-style tokens are filled by the deploy service; the
# {{ with secret … }} blocks are consul-template syntax, passed through
# verbatim for the Nomad client to resolve against Vault at runtime.
job "{{app_id}}" {
  type        = "service"
  region      = "global"
  datacenters = ["{{region}}"]
  namespace   = "tenant-{{tenant}}"

  constraint {
    attribute = "${meta.role}"
    value     = "prod"
  }

  group "app" {
    count = 1

    network {
      port "http" { to = 8080 }
    }

    service {
      name     = "{{app_id}}"
      port     = "http"
      provider = "nomad"
      tags     = ["urlprefix-{{url}}", "gate-{{gate_summary}}"]
      check {
        type     = "http"
        path     = "/health"
        interval = "10s"
        timeout  = "2s"
      }
    }

    task "web" {
      driver = "docker" # isolation swap point: firecracker/gvisor is a driver change only

      config {
        image = "{{image}}"
      }

      vault {
        # The policy the deploy service really mounts at first promote (#9):
        # sys/policies/acl/tenant-{{tenant}} — transit + database paths.
        policies = ["tenant-{{tenant}}"]
      }

      template {
        # Dynamic Postgres creds, 1h TTL, revoked when the allocation stops.
        # tenant-app is the shared staging DB role (#9); per-tenant roles
        # are a Phase 1 (cloud) item.
        data        = <<EOT
{{ with secret "database/creds/tenant-app" }}
DATABASE_URL=postgres://{{ .Data.username }}:{{ .Data.password }}@postgres.internal:5432/{{database}}
{{ end }}
EOT
        destination = "secrets/db.env"
        env         = true
      }

      env {
        APP_VERSION  = "{{app_version}}"
        HIPAA_CORE   = "enabled"
        AUDIT_STREAM = "https://audit.internal/ingest"
      }
    }
  }
}
